{
  "manifest_version": 3,
  "name": "Emdash Cookie Helper",
  "version": "1.0.0",
  "description": "Copy site cookies to clipboard for Emdash integrations",
  "permissions": ["cookies", "activeTab", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
