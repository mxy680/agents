{
  "manifest_version": 3,
  "name": "Engagent Cookie Capture",
  "version": "1.0.0",
  "description": "Capture session cookies for Engagent integrations",
  "permissions": ["cookies", "activeTab"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.instagram.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://*.streeteasy.com/*",
    "https://*.zillow.com/*",
    "https://*.instructure.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
