[Unit]
Description=Agents Portal (Next.js)
After=network.target docker.service

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/agents/portal
ExecStart=/usr/bin/doppler run -p agents -c prd -- /usr/bin/npm start
Restart=always
RestartSec=5
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
