{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../../out/preload",
    "composite": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["**/*.ts"]
}
